# -----------------------------------------------------------------------------
# Diyou 足球队档案站 - Docker 部署环境变量示例
# 复制本文件为 .env 并按实际情况修改
# -----------------------------------------------------------------------------

# 访问地址
# - 仅局域网使用：可保持 localhost，通过 NAS IP 访问
# - 有公网域名：填写你的域名，例如 nas.yourdomain.com
SITE_ADDRESS=localhost

# Web 端口
HTTP_PORT=80
HTTPS_PORT=443

# 后端安全密钥（部署前必须修改！）
# 生成方式（任选其一）：
#   - openssl rand -base64 32
#   - node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 建议每 6–12 个月轮换一次；轮换后所有已登录用户需重新登录。
JWT_SECRET=change_me

# 初始管理员账号（部署前必须修改！）
# 当前版本已删除默认密码回退，若不设置 ADMIN_PASSWORD，启动时不会创建管理员。
# 密码强度要求：至少 8 位，同时包含大写字母、小写字母和数字。
ADMIN_EMAIL=admin@diyou.test
ADMIN_PASSWORD=change_me

# 后端监听地址
# - Docker 容器内必须保持 0.0.0.0，否则 Caddy 无法反向代理到后端
# - 本地裸机运行可改为 127.0.0.1
HOST=0.0.0.0

# 数据库和文件存储路径（容器内路径，通常无需修改）
DATABASE_URL=file:/data/db/diyou.db
STORAGE_ROOT=/data/storage

# 跨域来源（生产环境建议指定为前端域名，多个用逗号分隔）
# 例如：CORS_ORIGIN=https://nas.yourdomain.com
# 仅用于本地测试时可保留 true
CORS_ORIGIN=true

# 全局请求频率限制（默认值通常足够）
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=1 minute

# -----------------------------------------------------------------------------
# 可选：真实邮箱验证码（SMTP）
# 配置后，邮箱验证码将通过真实邮件发送；未配置时仅在控制台打印验证码。
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@diyouzuqiu.com
# -----------------------------------------------------------------------------
