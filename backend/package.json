{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "start:prod": "npm run db:migrate && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai": "tsx src/lib/ai/json.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.0",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.7.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.0.1",
    "file-type": "^22.0.1",
    "jsdom": "^29.0.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^9.0.1",
    "pdf-parse-new": "^2.0.0",
    "read-excel-file": "^5.8.7",
    "sharp": "^0.34.1",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/jsdom": "^28.0.1",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.1.9",
    "prisma": "^7.8.0",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
