{$SITE_ADDRESS:localhost} {
    root * /srv
    encode gzip

    # Keep API/static routes out of the SPA fallback to avoid accidental
    # rewrites of non-GET requests.
    handle /api/* {
        reverse_proxy {$BACKEND_URL:diyou-backend:3000}
    }

    handle /static-storage/* {
        reverse_proxy {$BACKEND_URL:diyou-backend:3000}
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
